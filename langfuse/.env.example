# Langfuse self-host secrets and bootstrap.
# Copy to `.env` and edit. `.env` is gitignored.

# --- Secrets (REGENERATE before any non-local deployment) ----------------------
# These defaults were rolled at scaffold time. Fine for localhost dev. Rotate
# them via the commented commands below before running on a network anyone else
# can reach.

# openssl rand -hex 32
ENCRYPTION_KEY=08c6fb65def713aa8fa6bd23772f335c569b656fd462e9dd7dc14b795628d261

# openssl rand -base64 32
NEXTAUTH_SECRET=YvsTTLZY3GJkwTelc6+gBeFdk0OHGfElMMTR67xSRWc=

# openssl rand -base64 16
SALT=CtruqRt94O3fDyjGqkYLKw==

# --- URLs ----------------------------------------------------------------------
# Langfuse default is :3000 but that frequently collides with other dev
# servers. docker-compose.override.yml remaps the host port to 3100 and the
# bring-up runbook expects that — match here.
NEXTAUTH_URL=http://localhost:3100

# --- First-run bootstrap (creates org + project + admin + API keys) ------------
# Filling these in lets you skip the web UI signup and go straight to a
# project with API keys ready for Symphony.
#
# REQUIRED: change at least
#   - LANGFUSE_INIT_USER_PASSWORD       (this is the admin login)
#   - LANGFUSE_INIT_PROJECT_SECRET_KEY  (your agents auth with this; treat as
#                                        an API token, ~32 chars random is
#                                        fine — `openssl rand -hex 24`)
# before running `docker compose up -d`. The placeholders below intentionally
# don't work as production credentials.
LANGFUSE_INIT_ORG_ID=symphony
LANGFUSE_INIT_ORG_NAME=Symphony
LANGFUSE_INIT_PROJECT_ID=linear-agents
LANGFUSE_INIT_PROJECT_NAME=linear-agents
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-symphony-local-dev
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-symphony-local-dev-CHANGE-ME    # ⚠ CHANGE
LANGFUSE_INIT_USER_EMAIL=enggabrieltorres@gmail.com
LANGFUSE_INIT_USER_NAME=Gabriel Torres
LANGFUSE_INIT_USER_PASSWORD=CHANGE-ME-strong-passphrase                # ⚠ CHANGE

# --- Telemetry to Langfuse Cloud about this deployment -------------------------
# Set false to opt out.
TELEMETRY_ENABLED=true
